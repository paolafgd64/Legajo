DJANGO_DEBUG=false
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
#DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_STATICFILES_STORAGE=whitenoise.storage.CompressedStaticFilesStorage

# Local PostgreSQL example. In production, use the PostgreSQL URL from your host
# provider instead of localhost.
# DATABASE_URL=postgresql://postgres:legajo@localhost:5432/legajodb

LEGAJO_CLOUDINARY_CLOUD_NAME=tu_cloud_name
LEGAJO_CLOUDINARY_API_KEY=tu_api_key
LEGAJO_CLOUDINARY_API_SECRET=tu_api_secret
LEGAJO_CLOUDINARY_FOLDER=legajo/libros

# Alternativa equivalente:
# CLOUDINARY_URL=cloudinary://tu_api_key:tu_api_secret@tu_cloud_name

# Correo saliente (Gmail SMTP)
LEGAJO_EMAIL_HOST=smtp.gmail.com
LEGAJO_EMAIL_PORT=587
LEGAJO_EMAIL_USE_TLS=true
LEGAJO_EMAIL_TIMEOUT=10
LEGAJO_EMAIL_HOST_USER=tu_correo@gmail.com
LEGAJO_EMAIL_HOST_PASSWORD=tu_app_password_gmail
LEGAJO_DEFAULT_FROM_EMAIL=Legajo <tu_correo@gmail.com>
